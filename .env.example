# Copier ce fichier en .env et remplir avec vos clés Supabase
# Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Production: désactiver les données démo
VITE_DEMO_MODE=false

# OAuth Apple (optionnel — laisser false ou absent en prod si non configuré)
VITE_APPLE_AUTH_ENABLED=false

# Support contact (affiché dans profil / à propos)
VITE_SUPPORT_EMAIL=support@rcconnect.app
VITE_SUPPORT_PHONE=+1 (469) 555-0100

# Google OAuth (Supabase Dashboard → Authentication → Providers → Google)
# 1. Activer Google dans Supabase
# 2. Créer des identifiants OAuth dans Google Cloud Console
# 3. Ajouter l'URL de redirection : https://your-project.supabase.co/auth/v1/callback
# 4. Dans Supabase → Authentication → URL Configuration :
#    Site URL = https://votre-projet.vercel.app
#    Redirect URLs (ajouter toutes les URLs utilisées) :
#      http://localhost:5174
#      http://localhost:5174/recovery
#      https://votre-projet.vercel.app
#      https://votre-projet.vercel.app/recovery
#      https://votre-projet-*.vercel.app   (preview deployments)

# Tests E2E uniquement — ne jamais committer (.env.test.local)
# TEST_ADMIN_EMAIL=
# TEST_ADMIN_PASSWORD=
# TEST_USER_EMAIL=
# TEST_USER_PASSWORD=
