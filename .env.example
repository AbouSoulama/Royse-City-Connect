# Copier ce fichier en .env et remplir avec vos clés Supabase
# Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Production: désactiver les données démo
VITE_DEMO_MODE=false

# OAuth Apple (optionnel — laisser false ou absent en prod si non configuré)
VITE_APPLE_AUTH_ENABLED=false

# Support contact (affiché dans profil / à propos)
VITE_SUPPORT_EMAIL=support@rcconnect.app
VITE_SUPPORT_PHONE=+1 (469) 555-0100

# URL publique de l'app (OBLIGATOIRE pour Google OAuth en production)
# Doit commencer par https:// — sans slash final
VITE_APP_URL=https://royse-city-connect.vercel.app

# Google OAuth — ERREUR "requested path is invalid" si mal configuré :
# Dans Supabase → Authentication → URL Configuration :
#   Site URL = https://royse-city-connect.vercel.app   (PAS sans https://)
#   Redirect URLs :
#     https://royse-city-connect.vercel.app
#     https://royse-city-connect.vercel.app/**
#     https://royse-city-connect.vercel.app/#home
#     http://localhost:5174

# Tests E2E uniquement — ne jamais committer (.env.test.local)
# TEST_ADMIN_EMAIL=
# TEST_ADMIN_PASSWORD=
# TEST_USER_EMAIL=
# TEST_USER_PASSWORD=
